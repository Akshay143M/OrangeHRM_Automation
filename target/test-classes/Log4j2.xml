<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

	<Appenders>

		<!-- Console Logs -->
		<Console name="ConsoleAppender"
			target="SYSTEM_OUT">

			<PatternLayout
				pattern="%d{dd-MM-yyyy HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>

		</Console>

		<!-- File Logs -->
		<File name="FileAppender"
			fileName="logs/AutomationLogs.log"
			append="true">

			<PatternLayout
				pattern="%d{dd-MM-yyyy HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>

		</File>

	</Appenders>

	<Loggers>

		<Root level="info">

			<AppenderRef ref="ConsoleAppender"/>

			<AppenderRef ref="FileAppender"/>

		</Root>

	</Loggers>

</Configuration>